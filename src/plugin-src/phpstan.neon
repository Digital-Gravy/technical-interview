parameters:
    level: 9
    paths:
        - .
    excludePaths:
        - tests
        - vendor
        - build
        - '**/*.test.php'
    stubFiles:
        - ../../vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    scanFiles:
        - ../../vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
        - ../../vendor/php-stubs/wp-cli-stubs/wp-cli-commands-stubs.php
